{
    "name": "wizcodepl/lunar-product-schemas",
    "description": "Migration-style schema builder for Lunar product types and attributes (toggle filterable/searchable/required, attach/detach attrs, rename, drop with data cleanup).",
    "type": "library",
    "license": "MIT",
    "keywords": ["lunar", "lunarphp", "laravel", "ecommerce", "schema", "migration", "product-attributes", "pim"],
    "authors": [
        {
            "name": "Wizcode",
            "homepage": "https://wizcode.pl"
        }
    ],
    "require": {
        "php": "^8.2",
        "lunarphp/core": "^1.3"
    },
    "require-dev": {
        "filament/filament": "^3.2",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "filament/filament": "Required for the bundled Schema Health admin page."
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test"
    },
    "autoload": {
        "psr-4": {
            "WizcodePl\\LunarProductSchemas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WizcodePl\\LunarProductSchemas\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WizcodePl\\LunarProductSchemas\\ProductSchemaServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
